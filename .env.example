# ==========================================
# USCEHub Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------------------------------------------
# Supabase Database
# Get these from: supabase.com → your project → Settings → Database → Connection string (URI)
# ------------------------------------------
DATABASE_URL="postgresql://postgres.YOURPROJECT:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOURPROJECT:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------
# NextAuth
# Generate secret by running: openssl rand -base64 32
# ------------------------------------------
NEXTAUTH_SECRET="paste-your-generated-secret-here"
NEXTAUTH_URL="https://uscehub.com"

# ------------------------------------------
# Admin email notifications (listing submissions) — via Resend
# ------------------------------------------
# These values are NEVER sent to the browser — server-side only.
# NOTIFY_TO is private: read in src/lib/email.ts, not exposed in any API or page.
#
# Setup:
#   1. Sign up at https://resend.com/signup (free tier: 3,000 emails/month)
#   2. Go to API Keys → Create API Key → copy the `re_...` string → paste as RESEND_API_KEY
#   3. Leave RESEND_FROM blank to send from Resend's test domain while developing.
#      For production: Resend → Domains → add `uscehub.com` → add the 3 DNS records
#      in Cloudflare → wait for verify → then set RESEND_FROM="USCEHub <noreply@uscehub.com>"
# ------------------------------------------
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM=""
NOTIFY_TO="your-private-recipient-address@example.com"

# ------------------------------------------
# Vercel Cron bearer-token auth
# Used by /api/cron/verify-jobs and any future cron route under /api/cron/*.
# REQUIRED IN PRODUCTION — env helper throws at request time if missing
# (see src/lib/env.ts → getCronSecret).
# Generate with: openssl rand -base64 32
# In Vercel's cron config, the bearer header is added automatically when
# CRON_SECRET is set in project env vars.
# ------------------------------------------
CRON_SECRET="paste-your-generated-secret-here"

# ------------------------------------------
# Database seed admin credentials
# Required by `npx prisma db seed` to create the initial admin user.
# Replaces the hardcoded admin password the audit flagged as P0-1
# (see docs/codebase-audit/TECH_DEBT_REGISTER.md).
#
# - Use a long, random password (20+ chars).
# - Never commit real values.
# - For production seeds, set these in CI secrets, not in a local .env
#   that could be uploaded.
# - Seed throws with a clear MissingEnvError if either is unset, so the
#   admin user is never created with an unknown/default password.
# ------------------------------------------
SEED_ADMIN_EMAIL="admin@uscehub.com"
SEED_ADMIN_PASSWORD="set-a-long-random-string-here"

# ------------------------------------------
# Admin-creation opt-in for seed (audit P0-3, fixed in cleanup PR6)
# Admin user creation in `npx prisma db seed` is OFF by default.
# Set to "1" only for intentional local/dev admin bootstrap; the env
# vars above (SEED_ADMIN_EMAIL + SEED_ADMIN_PASSWORD) are then required.
# Never rely on default admin credentials.
# ------------------------------------------
SEED_CREATE_ADMIN="0"

# ------------------------------------------
# Optional client-side feature flags (NEXT_PUBLIC_*).
# These ARE inlined into the browser bundle by Next.js — never put a
# secret in a NEXT_PUBLIC_* var.
#
# NEXT_PUBLIC_ENABLE_PHASES: when set to "1", reveals the multi-phase
# journey UI (medical-graduate / resident / attending). Default off.
# ------------------------------------------
NEXT_PUBLIC_ENABLE_PHASES=""
